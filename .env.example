# Copy to .env on the VPC host (do not commit .env).
# Used by docker compose for local/manual builds and as fallbacks.

NEXT_PUBLIC_CELL_NAME=msb
NEXT_PUBLIC_APK_URL=

# Set by CD when deploying a pre-built image from GHCR, e.g.:
# LANDING_IMAGE=ghcr.io/<org>/frontend-landing:abc123def456
# LANDING_IMAGE=frontend-landing:local
